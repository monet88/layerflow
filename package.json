{
  "name": "inpaintkit",
  "version": "1.0.0",
  "description": "AI image editing plugin for Adobe Photoshop (UXP)",
  "private": true,
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build",
