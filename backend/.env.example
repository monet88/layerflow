# Shared secret for API authorization with InpaintKit plugin
APP_API_KEY=dev-app-key

# Provider configuration: mock | chatgpt_web
IMAGE_PROVIDER=mock

# Local database file path
SQLITE_PATH=data/app.sqlite

# Max upload limit in MB
MAX_UPLOAD_MB=20

# Fernet encryption key for credentials storage. MUST be urlsafe-base64 44-char.
# Generate one using:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Logs verbosity
LOG_LEVEL=INFO

# Optional HTTP/SOCKS proxy for ChatGPT API traffic
CHATGPT_PROXY=

# Allowed cross-origin lists
ALLOWED_ORIGINS=app://uxp-internal,http://localhost:8000
